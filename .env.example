# Runtime overrides for project root or release root.
# Local development:
# - backend (mvn spring-boot:run) reads this file via spring.config.import
# - frontend (npm run dev) uses BACKEND_HOST/BACKEND_PORT as proxy priority
# Release runtime:
# - frontend/server.js reads this file directly

# Network / 网络
BACKEND_HOST=127.0.0.1
# Shared backend port source for backend + frontend dev proxy when this file is present.
BACKEND_PORT=11946
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=11947

# Web auth / 网页认证
AUTH_ENABLED=true
AUTH_USERNAME=admin
# IMPORTANT: Change this bcrypt hash before production.
# 重要：上线前必须替换为你自己的管理员密码 bcrypt 哈希。
AUTH_PASSWORD_HASH_BCRYPT='$2a$10$XkbhEhxiT/4JC.zkZD9uxuEFf7za4AxEBPbIFmUR41qY0.spPk41q'
AUTH_SESSION_TTL_SECONDS=43200
AUTH_LOGIN_RATE_LIMIT_ENABLED=true
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10

# App JWT auth / App JWT 认证
APP_AUTH_ENABLED=true
APP_AUTH_LOCAL_PUBLIC_
APP_AUTH_JWKS_URI=
APP_AUTH_ISSUER=http://localhost:8080
APP_AUTH_JWKS_CACHE_SECONDS=300
APP_AUTH_AUDIENCE=
APP_AUTH_CLOCK_SKEW_SECONDS=30

# Terminal files
TERMINAL_FILES_ENABLED=false

# SSH / SSH 配置
TERMINAL_SSH_CREDENTIALS_FILE=data/ssh-credentials.json
# IMPORTANT: Replace this demo key with a strong random secret (32+ chars).
# 重要：必须修改为强随机密钥（建议 32 位以上），不要使用示例值。
TERMINAL_SSH_MASTER_KEY=set_a_strong_random_key
